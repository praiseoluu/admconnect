# KTG Connect API — Environment Configuration
# Copy to .env and fill in real values.
# These are read by config/database.php and config/jwt.php via getenv().
#
# For Apache: set via SetEnv in VirtualHost or .htaccess
# For Nginx+PHP-FPM: set via fastcgi_param or env[] in pool config
# For CLI: export before running setup.php

DB_HOST=localhost
DB_PORT=3306
DB_NAME=afx_connect
DB_USER=afx_user
DB_PASS=your_strong_password_here

# CRITICAL: Change this before going to production!
# Generate with: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_IN_PRODUCTION

# Token lifetime in seconds (default: 2592000 = 30 days)
JWT_EXPIRES_IN=2592000

# Base URL for constructing avatar URLs (no trailing slash)
BASE_URL=https://adamawakonect.com/server/api/v1

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────
# Step 1: https://developers.facebook.com → Create App → WhatsApp product
# Step 2: Add a phone number and get the Phone Number ID (not the actual number)
# Step 3: Create a System User at business.facebook.com → System Users, generate
#         a permanent token with whatsapp_business_messaging permission
# Step 4: Create message templates in WhatsApp Manager and submit for approval:
#         - WHATSAPP_OTP_TEMPLATE: one variable {{1}} = the OTP code
#         - WHATSAPP_INVITE_TEMPLATE: one variable {{1}} = the signup link
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_permanent_system_user_token_here
WHATSAPP_OTP_TEMPLATE=afx_otp
WHATSAPP_INVITE_TEMPLATE=afx_invite
WHATSAPP_API_VERSION=v19.0

# Dev/testing fallback — set this to bypass real WhatsApp delivery and always
# accept this fixed code. Must be exactly 4 digits for phone OTPs or 6 digits
# for identity/password-reset OTPs. Remove or leave blank in production.
WHATSAPP_DEV_OTP=

# ── Resend (Email) ────────────────────────────────────────────────────────
# Step 1: https://resend.com/api-keys → Create API key (full access)
# Step 2: https://resend.com/domains → Add and verify adamawakonect.com (add DNS records)
# Step 3: Use a verified sender address below
# Your API key starts with re_ — store it in server/.env (never commit .env)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@adamawakonect.com
RESEND_FROM_NAME=ADM Connect

# ── IDrive e2 (S3-compatible object storage) ──────────────────────────────
# Dashboard: https://app.idrive.com/e2/buckets
# Step 1: Create a bucket (e.g. afx-connect), set Access Policy to Public
# Step 2: Generate an Access Key under Security → Access Keys
# Step 3: The endpoint is shown on the bucket detail page (e.g. https://n8i5.c17.e2-object.com)
# Step 4: S3_PUBLIC_URL is the base URL for serving objects — usually endpoint/bucket-name
S3_ENDPOINT=https://n8i5.c17.e2-object.com
S3_REGION=us-east-1
S3_BUCKET=afx-connect
S3_KEY=your_access_key_id
S3_SECRET=your_secret_access_key
# Note: objects are served privately via the /media proxy — no public bucket URL needed

# ── Cron (scheduled news publishing) ─────────────────────────────────────
# Use this as the ?secret= query param when calling /cron/publish-scheduled
# Configure cPanel to call: GET BASE_URL/cron/publish-scheduled?secret=CRON_SECRET
CRON_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET
